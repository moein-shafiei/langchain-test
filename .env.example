# ─── Azure OpenAI ────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Deployment names (must match names in your Azure portal)
AZURE_ROUTER_DEPLOYMENT=gpt-4o-mini          # Lightweight model for classification
AZURE_EXTRACTION_DEPLOYMENT=gpt-4o           # Full model for structured extraction
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small  # Embeddings for RAG knowledge base

# ─── Extraction Tuning ────────────────────────────────────────────────────────
# Minimum confidence score before routing to human review (0.0 – 1.0)
CONFIDENCE_THRESHOLD=0.50

# Maximum self-correction attempts before escalating to human review
MAX_EXTRACTION_ATTEMPTS=2

# PDFs with more pages than this threshold are chunked before extraction
CHUNK_THRESHOLD_PAGES=15

# ─── Paths ───────────────────────────────────────────────────────────────────
CHECKPOINT_DB_PATH=checkpoints.db
OUTPUT_DIR=output
